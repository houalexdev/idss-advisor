# Copy this file to .env and fill in your values:
#   cp env.example .env

# ── DeepSeek API（推荐）──────────────────────────────────────────────────────
# 优先级最高，设置后自动切换到 DeepSeek 模式
# 获取 Key：https://platform.deepseek.com
DEEPSEEK_API_KEY=

# ── Moonshot AI / Kimi ──────────────────────────────────────────────────────
# 未设置 DEEPSEEK_API_KEY 时使用
# 获取 Key：https://platform.moonshot.cn
MOONSHOT_API_KEY=

# ── 说明 ────────────────────────────────────────────────────────────────────
# - 两个 Key 都不设置 → Mock 演示模式（零延迟，内置知识库）
# - 仅设置 MOONSHOT_API_KEY → Kimi 模式
# - 设置 DEEPSEEK_API_KEY → DeepSeek 模式（优先）
# - Ollama 在 UI 里配置，无需环境变量
